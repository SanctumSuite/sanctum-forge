# Logging verbosity: DEBUG | INFO | WARNING | ERROR
FORGE_LOG_LEVEL=INFO

# Ollama endpoint used for image OCR (vision models).
# macOS/Windows: host.docker.internal; Linux: use the bridge gateway if needed.
FORGE_OLLAMA_URL=http://host.docker.internal:11434

# Comma-separated list of vision-capable OCR models to try in order.
# Install with: ollama pull deepseek-ocr
FORGE_OCR_MODELS=deepseek-ocr:latest
